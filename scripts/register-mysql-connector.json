{
  "name": "mysql-connector",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",
    "database.hostname": "mysql",
    "database.port": "3307",
    "database.user": "debezium",
    "database.password": "dbzpass",
    "database.server.id": "184054",
    "database.server.name": "foodapp",
    "topic.prefix": "foodapp",
    "database.include.list": "Food_Application_Platform",
    "table.include.list": "food_application_platform.restaurants,food_application_platform.menu",
    "database.history.kafka.bootstrap.servers": "kafka:9092",
    "database.history.kafka.topic": "schema-changes.foodapp.v2",
    "include.schema.changes": "true",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter"
  }
}
